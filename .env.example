# Saunter — all optional. The app runs with none of these set.
#
# Without GROQ_API_KEY: tours still generate; blurbs are grounded copy
# trimmed straight from Wikipedia/OSM instead of the LLM voice pass.
# Get a free key at https://console.groq.com
GROQ_API_KEY=

# Without DATABASE_URL: generated tours are cached in process memory
# (lost on restart). Set a Neon/Postgres URL for durable, shareable links.
# Example: postgres://user:pass@host/db?sslmode=require
DATABASE_URL=
